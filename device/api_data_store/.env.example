# Environment Configuration
# Copy this file to .env and fill in the values

# MQTT Broker Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Firebase Configuration  
# Path to Firebase service account JSON file (relative to this folder or absolute path)
FIREBASE_CREDENTIALS=../../backend/research-2-3478d-firebase-adminsdk-fbsvc-335af8ca98.json

# Socket.IO Configuration
SOCKET_PORT=5001
SOCKET_CORS_ORIGINS=*

# API Configuration
API_PORT=5001

# Backend API URL (for route validation)
BACKEND_API_URL=http://localhost:5000
